    "about.legalText1" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese App ist ein unabhängiges Projekt und steht in keiner Verbindung zu Apple Inc. Apple, Apple TV, tvOS und Safari sind eingetragene Marken von Apple Inc."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app is an independent project and is not affiliated with Apple Inc. Apple, Apple TV, tvOS, and Safari are registered trademarks of Apple Inc."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta app es un proyecto independiente y no está afiliada a Apple Inc. Apple, Apple TV, tvOS y Safari son marcas registradas de Apple Inc."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette application est un projet indépendant et n'est pas affiliée à Apple Inc. Apple, Apple TV, tvOS et Safari sont des marques déposées d'Apple Inc."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questa app è un progetto indipendente e non è affiliata ad Apple Inc. Apple, Apple TV, tvOS e Safari sono marchi registrati di Apple Inc."
          }
        }
      }
    },
    "about.legalText2" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suchergebnisse werden über externe APIs bereitgestellt. Wikipedia-Inhalte unterliegen der Creative Commons Lizenz (CC BY-SA 3.0)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Search results are provided through external APIs. Wikipedia content is subject to the Creative Commons License (CC BY-SA 3.0)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los resultados de búsqueda se proporcionan a través de APIs externas. El contenido de Wikipedia está sujeto a la Licencia Creative Commons (CC BY-SA 3.0)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les résultats de recherche sont fournis via des APIs externes. Le contenu Wikipédia est soumis à la licence Creative Commons (CC BY-SA 3.0)."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I risultati di ricerca sono forniti tramite API esterne. Il contenuto di Wikipedia è soggetto alla licenza Creative Commons (CC BY-SA 3.0)."
          }
        }
      }
