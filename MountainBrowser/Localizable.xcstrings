{
  "sourceLanguage" : "en",
  "strings" : {
    "" : {

    },
    "%@ Tab" : {
      "comment" : "The accessibility label for a tab in the search interface. The placeholder is replaced with the name of the tab.",
      "isCommentAutoGenerated" : true
    },
    "%@: %@" : {
      "comment" : "A view that displays an error message with a retry button. The argument is the error message to display.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@: %2$@"
          }
        }
      }
    },
    "%@. %@" : {
      "comment" : "A label that combines the title and description of a search result, followed by a hint to tap the card twice to open it.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@. %2$@"
          }
        }
      }
    },
    "%lld %@" : {
      "comment" : "A label showing the number of tabs. The argument is the count of tabs.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld %2$@"
          }
        }
      }
    },
    "%lld × %lld" : {
      "comment" : "A badge displaying the width and height of an image in pixels. The first argument is the width of the image in pixels. The second argument is the height of the image in pixels.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld × %2$lld"
          }
        }
      }
    },
    "%lld Ergebnisse gefunden" : {
      "comment" : "A subheading indicating the number of search results found. The argument is the count of results.",
      "isCommentAutoGenerated" : true
    },
    "%lld Suchergebnisse gefunden" : {
      "comment" : "A label at the top of the search results view indicating the number of results found. The argument is the number of results.",
      "isCommentAutoGenerated" : true
    },
    "%lld%%" : {
      "comment" : "A text label displaying the percentage of the webpage that has been scrolled. The text is centered and has a monospaced font.",
      "isCommentAutoGenerated" : true
    },
    "•" : {
      "comment" : "A bullet point character used in lists.",
      "isCommentAutoGenerated" : true
    },
    "Abbrechen" : {
      "comment" : "A button that dismisses an alert without taking any action.",
      "isCommentAutoGenerated" : true
    },
