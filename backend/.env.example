# AppleTV Browser Backend Environment Variables
# Kopiere diese Datei zu .env und trage deine echten API-Keys ein

# Bing Search API Key (Required)
# Erstelle einen Key unter: https://portal.azure.com
# Suche nach "Bing Search v7" und erstelle eine neue Resource
BING_API_KEY=your_bing_search_api_key_here

# Optional: Zusätzliche Konfiguration
NODE_ENV=development